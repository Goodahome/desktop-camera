{
  "name": "desktop-camera",
  "version": "1.1.0",
  "description": "方便好用的桌面摄像头软件，适合直播、录课、内容分享时使用",
  "main": "./out/main/index.js",
  "author": "Goodahome",
  "homepage": "https://github.com/Goodahome/desktop-camera",
  "repository": "https://github.com/Goodahome/desktop-camera",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps || echo \"原生模块编译跳过（若需 UVC 控制请安装 Visual Studio 生成工具后执行 pnpm run rebuild）\"",
    "rebuild": "electron-rebuild -f",
    "build:win": "npm run build && electron-builder --win --config --publish never",
    "build:linux": "npm run build && electron-builder --linux --config --publish never",
    "build:mac": "npm run build && electron-builder --mac --config --publish never",
    "build:mac-arm": "npm run build && electron-builder --arm64 --config --publish never",
    "build:mac-mas": "npm run build && electron-builder --mac --config electron-builder-mas.yml --publish never"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@icon-park/vue-next": "^1.4.2",
    "axios": "^1.13.6",
    "electron-updater": "^6.8.3",
    "electron-vite": "^5.0.0",
    "element-plus": "^2.13.5",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "uvc-control": "^1.0.2",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^3.6.0",
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/node": "25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "less": "^4.6.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "scss": "^0.2.4",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.9.3",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
